# Copy this file to `.env` and fill in real values there.
# NEVER put real keys in this file — `.env.example` is committed to git.

# Supabase (Project Settings → API Keys)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...  # "Secret key" in Supabase UI (formerly service_role). NOT the Publishable/anon key.

# LLM provider: anthropic | groq | glm
LLM_PROVIDER=groq

# Fill in only the provider you chose
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GLM_API_KEY=...

# Optional: override models
# ANTHROPIC_MODEL=claude-haiku-4-5
# GROQ_MODEL=llama-3.3-70b-versatile
# GLM_MODEL=glm-4-flash
